<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" 
	xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" 
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

	<munit:config name="main-test-suite.xml" />

	<munit:before-suite name="main-before-suite" doc:id="a983a0bd-0172-4234-9793-9c88788f2d2c">
		<munit-tools:store key="test.environment" doc:id="56e450c5-147d-4856-a70b-0244aaeb63ca">
			<munit-tools:value>#["test"]</munit-tools:value>
		</munit-tools:store>
		<logger level="INFO" doc:id="5e4978db-720b-48b4-8203-becfd7b2e2f8"
		        message="Starting main Test Suite"/>
	</munit:before-suite>

	<munit:test name="daily-token-refresh-flowTest"
	            doc:id="e4419b2f-d408-489b-b328-ae1bfd82f8f3"
	            description="Test daily-token-refresh-flow - remove">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock os:remove"
			                        doc:id="269a60c1-17ac-4ccf-bde8-56e5a5b088b2"
			                        processor="os:remove">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="doc-f2536e82" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[output application/java --- {"success":true}]'
					                      mediaType="application/java"
					                      encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock process-info-logger-sub-flow" doc:id="8df6072f-73b1-4e91-bf93-400ac544c1c8" processor="flow-ref">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="process-info-logger-sub-flow" attributeName="name"/>
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[payload]' mediaType="application/json" encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock get-salesforce-access-token-sub-flow" doc:id="5d4c11c1-69e6-411a-bfe1-82901249713a" processor="flow-ref">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="get-salesforce-access-token-sub-flow" attributeName="name"/>
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[payload]' mediaType="application/json" encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock process-info-logger-sub-flow" doc:id="88c71d44-7f32-48fd-963f-0bf18164e211" processor="flow-ref">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="process-info-logger-sub-flow" attributeName="name"/>
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[payload]' mediaType="application/json" encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>

		<munit:execution>
			<flow-ref doc:name="Flow-ref to daily-token-refresh-flow"
			          doc:id="14b622e9-5cc0-492d-860e-82a71cca4427"
			          name="daily-token-refresh-flow"/>
		</munit:execution>

		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null"
			                          doc:id="adf2e698-5f65-4748-ba09-b5e0d3ca1d0c"
			                          expression="#[payload]"
			                          is="#[MunitTools::notNullValue()]"/>

			<logger level="INFO" doc:id="8010c689-95a7-4790-9488-3f0e3394f822"
			        message="#['Test payload: ' ++ write(payload, 'application/json')]"/>
		</munit:validation>
	</munit:test>


	<munit:after-suite name="main-after-suite" doc:id="3cba4fe8-9c16-4fc8-9f5d-d1e54aaccd50">
		<logger level="INFO" doc:id="6c2136e5-798b-42f1-b9c1-dc9001dcb149"
		        message="main Test Suite completed successfully"/>
	</munit:after-suite>

</mule>