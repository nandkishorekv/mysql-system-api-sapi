					<munit-tools:payload value='#[payload]' mediaType="application/json" encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>

		<munit:execution>
			<!-- Setup Mule event with variables -->
			<munit:set-event doc:name="Set Event" doc:id="d813fb18-fea7-4ebf-8986-9684501cefbd">
				<munit:variables>
					<munit:variable key="cachedSalesforceToken" value='#["test-cachedSalesforceToken"]' />
					<munit:variable key="salesforceAccessToken" value='#["test-salesforceAccessToken"]' />
					<munit:variable key="salesforceInstanceUrl" value='#["test-salesforceInstanceUrl"]' />
				</munit:variables>
