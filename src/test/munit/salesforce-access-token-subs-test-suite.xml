				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="doc-93563d45" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[output application/java --- {"id":1,"value":"test-value"}]'
					                      mediaType="application/java"
					                      encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock process-info-logger-sub-flow" doc:id="1c5e69c8-66ba-442e-85a7-1e5567303871" processor="flow-ref">
				<munit-tools:with-attributes>
