			                          expression="#[payload]"
			                          is="#[MunitTools::notNullValue()]"/>

			<logger level="INFO" doc:id="1ea087e3-e3ff-4d54-963e-6d3d57e7055d"
			        message="#['Test payload: ' ++ write(payload, 'application/json')]"/>
		</munit:validation>
