<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" 
	xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" 
	xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">

	<munit:config name="azure-keyvault-secret-subs-test-suite.xml" />

	<munit:before-suite name="azure-keyvault-secret-subs-before-suite" doc:id="2a79579a-0dd8-4da1-b9f6-643b16444aee">
		<munit-tools:store key="test.environment" doc:id="db49d0c6-3913-4bd5-abf3-88edea3a5a33">
			<munit-tools:value>#["test"]</munit-tools:value>
		</munit-tools:store>
		<logger level="INFO" doc:id="6b95f50a-8928-48a6-afcd-22ac5385d722"
		        message="Starting azure-keyvault-secret-subs Test Suite"/>
	</munit:before-suite>

	<munit:test name="fetch-azure-keyvault-secret-sub-flowTest"
	            doc:id="87ee4e3d-0b8a-4a4c-ab3f-6024eadf0b31"
	            description="Test fetch-azure-keyvault-secret-sub-flow - flow execution">
		<munit:behavior>
			<munit-tools:mock-when doc:name="Mock http:request"
			                        doc:id="5b27fcc9-a096-4b41-8694-fa7b69ba8445"
			                        processor="http:request">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="doc-6a75fe10" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[output application/json --- {"id":1,"success":true}]'
					                      mediaType="application/json"
					                      encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock process-info-logger-sub-flow" doc:id="78e28455-0e33-4464-b5b1-387cbb2efee5" processor="flow-ref">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="process-info-logger-sub-flow" attributeName="name"/>
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[payload]' mediaType="application/json" encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock process-info-logger-sub-flow" doc:id="31321d02-40ec-4958-8b4e-c8e79b7297ff" processor="flow-ref">
				<munit-tools:with-attributes>
					<munit-tools:with-attribute whereValue="process-info-logger-sub-flow" attributeName="name"/>
				</munit-tools:with-attributes>
				<munit-tools:then-return>
					<munit-tools:payload value='#[payload]' mediaType="application/json" encoding="UTF-8"/>
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>

		<munit:execution>
			<!-- Setup Mule event with variables -->
			<munit:set-event doc:name="Set Event" doc:id="36c5c39e-ec28-4678-b715-244ea206379c">
				<munit:variables>
					<munit:variable key="keyVaultResponse" value='#["test-keyVaultResponse"]' />
					<munit:variable key="salesforceClientSecret" value='#["test-salesforceClientSecret"]' />
				</munit:variables>
			</munit:set-event>

			<flow-ref doc:name="Flow-ref to fetch-azure-keyvault-secret-sub-flow"
			          doc:id="06a6e913-9c2a-4c6f-8c00-72ff4eac3813"
			          name="fetch-azure-keyvault-secret-sub-flow"/>
		</munit:execution>

		<munit:validation>
			<munit-tools:assert-that doc:name="Assert payload not null"
			                          doc:id="c981e0de-acc6-4e67-bdad-64d3c3db865e"
			                          expression="#[payload]"
			                          is="#[MunitTools::notNullValue()]"/>

			<logger level="INFO" doc:id="bcf26912-29b2-4a12-a6e5-81d1eecd3b89"
			        message="#['Test payload: ' ++ write(payload, 'application/json')]"/>
		</munit:validation>
	</munit:test>


	<munit:after-suite name="azure-keyvault-secret-subs-after-suite" doc:id="eef99e59-ba01-4df6-8a6f-4ba30de5a32e">
		<logger level="INFO" doc:id="705d0638-da54-46f6-926b-ec5224ce6bfb"
		        message="azure-keyvault-secret-subs Test Suite completed successfully"/>
	</munit:after-suite>

</mule>