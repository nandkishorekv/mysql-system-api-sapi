#%RAML 1.0 DataType
type: object
properties:
  correlationId:
    type: string
  batchId:
    type: string
  files:
    type: array
    items:
      type: object
      properties:
        fileName:
          type: string
        fileContent:
          type: string
        mimeType:
          type: string
        serverRelativeUrl:
          type: string
        lastModifiedDateTime:
          type: datetime
        fileSize:
          type: number
        fileExtension:
          type: string
