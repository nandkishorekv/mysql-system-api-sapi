	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">
	<sub-flow name="logger-info-debug-sub-flow" doc:id="61fae99e-e24e-478d-a137-97e608760ae8" >
		<choice doc:name="Choice" doc:id="940ed6c7-54cd-4db2-98b4-88c2639bce6a" >
			<when expression="#[vars.priority == p('priority.debug')]">
				<logger level="DEBUG" doc:name="Debug Logger with Payload" doc:id="704861ff-4af3-4bef-88c1-9fbd5f106e05" message="#[%dw 2.0&#10;import * from dwl::logging::logger&#10;output application/json&#10;--- &#10;log(vars.logger.env, vars.logger.priority, vars.logger.tracePoint, vars.logger.process, vars.logger.sourceSystem, vars.logger.targetSystem, vars.logger.flowName, vars.logger.correlationId, vars.logger.api, vars.logger.content)]" />
			</when>
			<otherwise >
				<logger level="INFO" doc:name="Info Logger without Payload" doc:id="533e2c4f-e637-41ab-876b-6113c203fba3" message="#[%dw 2.0&#10;import * from dwl::logging::logger&#10;output application/json&#10;---&#10;log(vars.logger.env, vars.logger.priority, vars.logger.tracePoint, vars.logger.process, vars.logger.sourceSystem, vars.logger.targetSystem, vars.logger.flowName, vars.logger.correlationId, vars.logger.api, vars.logger.content)]" />
			</otherwise>
		</choice>
	</sub-flow>
	<sub-flow name="logger-sub-flow" doc:id="e094739d-8118-453d-b78f-ee451e5fd9eb" >
		<ee:transform doc:name="payload for logger" doc:id="3d3fbcfb-6f4d-4f5b-82d8-857fc35bbcbb">
			<ee:message>
			</ee:message>
			<ee:variables>
				<ee:set-variable variableName="logger"><![CDATA[%dw 2.0
output application/json
---
{ 
    "priority": vars.priority as String, 
    "correlationId": (vars.apiDetails.correlationId default vars.correlationId) as String, 
    "timestamp": now(),
    "env": p('mule.env') as String,
    "api": p('api.name'),  
    "flowName" : vars.flowName default "",
    "tracePoint": vars.tracePoint as String,
    "process": vars.apiDetails.endpoint default vars.endpointDetails.endpoint default "",
    "sourceSystem" : vars.apiDetails.source default vars.endpointDetails.source default " ",
    "targetSystem" : vars.apiDetails.target default vars.endpointDetails.target  default " ",
    "content": vars.logData default {}
}
]]></ee:set-variable>
			</ee:variables>
		</ee:transform>
		<flow-ref doc:name="logger-info-debug-sub-flow" doc:id="d12dbf26-e120-4823-a0b0-24bd481935de" name="logger-info-debug-sub-flow"/>
	</sub-flow>
	<sub-flow name="request-received-logger-sub-flow" doc:id="dc618128-246b-4dbe-9f95-32f2800f2fca" >
		<set-variable value="#[p('tracePoint.request')]" doc:name='tracePoint "REQUEST_RECEIVED"' doc:id="9b65a289-4d9c-40c1-b39a-57a87e21e1e7" variableName="tracePoint"/>
		<set-variable value="#[p('priority.debug')]" doc:name='priority "DEBUG"' doc:id="bd041076-12e7-4fe6-99b9-62cc52fe3227" variableName="priority"/>
		<flow-ref doc:name="logger-sub-flow" doc:id="f6e741be-089d-4ae3-a340-0224c129229d" name="logger-sub-flow" />
	</sub-flow>
	<sub-flow name="response-returned-logger-sub-flow" doc:id="f358f60a-ef13-47d3-b941-4e4106b6c0ae" >
